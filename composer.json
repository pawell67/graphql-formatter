{
    "name": "pawell67/graphql-formatter",
    "description": "Opinionated formatter for .gql and .graphql files",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "webonyx/graphql-php": "^15.0",
        "symfony/console": "^7.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.94",
        "phpunit/phpunit": "^11.0|^12.0|^13.0"
    },
    "autoload": {
        "psr-4": { "GraphQLFormatter\\": "src/" }
    },
    "autoload-dev": {
        "psr-4": { "GraphQLFormatter\\Tests\\": "tests/" }
    },
    "bin": ["bin/graphql-formatter"],
    "scripts": {
        "cs-fix": "php-cs-fixer fix",
        "cs-check": "php-cs-fixer fix --dry-run --diff",
        "test": "vendor/bin/phpunit tests/"
    },
    "config": { "sort-packages": true }
}
