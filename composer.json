{
    "name": "pawell67/graphql-formatter",
    "description": "Opinionated formatter for .gql and .graphql files",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "webonyx/graphql-php": "^15.0",
        "symfony/console": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": { "GraphQLFormatter\\": "src/" }
    },
    "autoload-dev": {
        "psr-4": { "GraphQLFormatter\\Tests\\": "tests/" }
    },
    "bin": ["bin/graphql-formatter"],
    "config": { "sort-packages": true }
}
